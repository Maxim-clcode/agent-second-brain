# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription
DEEPGRAM_API_KEY=

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot (empty = allow all)
# The FIRST id also receives health alerts / daily reports.
ALLOWED_USER_IDS=[123456789]

# Timezone for systemd timers and reports (e.g. Asia/Tashkent, Europe/Moscow)
TZ=UTC

# Model for the persistent session. Empty = Claude Code default (Opus).
# Set to "sonnet" to reduce weekly-limit pressure for a 24/7 bot.
CLAUDE_MODEL=

# Scheduled jobs (the agent manages them itself via the cron skill).
# Defaults are sensible; set CRON_ENABLED=false to turn the ticker off.
CRON_ENABLED=true

# ── Advanced (defaults are fine — uncomment only if you know why) ──
# Runtime dir for session locks/logs and cron state (must be a LOCAL fs)
#RUNTIME_DIR=~/.dbrain
# tmux session name (empty = generated and persisted per install)
#BRAIN_SESSION_NAME=
# Allow EVERYONE to talk to the bot — security risk, leave false
#ALLOW_ALL_USERS=false
# Cron tuning: ticker interval / per-job timeout / failures before
# auto-disable / retry delay for a failed one-shot
#CRON_TICK_SECONDS=60
#CRON_JOB_TIMEOUT=600
#CRON_MAX_CONSECUTIVE_ERRORS=3
#CRON_RETRY_SECONDS=300
