# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription
DEEPGRAM_API_KEY=

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot (empty = allow all)
# The FIRST id also receives health alerts / daily reports.
ALLOWED_USER_IDS=[123456789]

# Timezone for systemd timers and reports (e.g. Asia/Tashkent, Europe/Moscow)
TZ=UTC

# Model for the persistent session. Empty = Claude Code default (Opus).
# Set to "sonnet" to reduce weekly-limit pressure for a 24/7 bot.
CLAUDE_MODEL=
